---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import { getClubSlugs, loadClubData } from "../lib/loadClubData";
import { getTheme } from "../lib/themes";
import type { DashboardData } from "../lib/types";

export function getStaticPaths() {
  const slugs = getClubSlugs();
  return slugs.map((slug) => ({
    params: { club: slug },
    props: { slug },
  }));
}

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const data: DashboardData = loadClubData(slug);
const theme = getTheme(slug);
const clubName = data.meta.club;
const seasonCount = data.seasons.length;
const teamCount = data.teams.filter((t) => t !== "All").length;
---

<BaseLayout
  title={`${clubName} — ClubStats`}
  description={`Cricket stats dashboard for ${clubName}`}
>
  <main
    class="flex min-h-screen flex-col items-center justify-center px-4 text-center"
  >
    <a href="/" class="mb-8 text-sm text-gray-500 hover:text-gray-700">
      &larr; Back to ClubStats
    </a>
    <div
      class="rounded-2xl border border-gray-200 bg-white p-10 shadow-sm"
      style={`border-top: 4px solid ${theme.primary}`}
    >
      <h1
        class="text-4xl font-extrabold tracking-tight"
        style={`color: ${theme.primary}`}
      >
        {clubName}
      </h1>
      <p class="mt-3 text-gray-500">
        {seasonCount} seasons &middot; {teamCount} teams &middot; Data captured {
          data.meta.capturedAt
        }
      </p>
      <p class="mt-6 text-lg text-gray-600">Dashboard coming in Phase 1.</p>
    </div>
  </main>
</BaseLayout>
