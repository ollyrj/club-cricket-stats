---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import "../styles/dashboard.css";
import { getClubSlugs, loadClubData } from "../lib/loadClubData";
import { getTheme } from "../lib/themes";
import type { DashboardData } from "../lib/types";
import { Dashboard } from "../components/dashboard/Dashboard";

export function getStaticPaths() {
  const slugs = getClubSlugs();
  return slugs.map((slug) => ({
    params: { club: slug },
    props: { slug },
  }));
}

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const data: DashboardData = loadClubData(slug);
const theme = getTheme(slug);
const clubName = data.meta.club;
---

<BaseLayout
  title={`${clubName} — ClubStats`}
  description={`Cricket stats dashboard for ${clubName}`}
>
  <Dashboard client:load data={data} theme={theme} />
</BaseLayout>
