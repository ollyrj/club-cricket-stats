---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import "../styles/landing.css";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Do you need access to our Play Cricket?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. We pull everything from the publicly available stats pages — you don't need to share any logins or passwords. Just tell us your club name and which XIs to include.",
      },
    },
    {
      "@type": "Question",
      name: "How current are the stats?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "On setup we pull every match from the last four seasons. During the season, we re-capture every Sunday night so Monday morning your URL is fresh.",
      },
    },
    {
      "@type": "Question",
      name: "Can I include the junior section too?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes — Under-9 through Under-18 cricket can be added as a bolt-on for £49. We add a separate Junior mode to the dashboard.",
      },
    },
    {
      "@type": "Question",
      name: "What's included in the £99/year renewal?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Weekly stats refresh through every season, all new feature releases, continued hosting, and email support. Cancel anytime.",
      },
    },
    {
      "@type": "Question",
      name: "Can we put it on our own club website?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Absolutely. The URL embeds in any club website via a single iframe tag. We send you the snippet on delivery.",
      },
    },
  ],
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "ClubStats Cricket Dashboard",
  description:
    "Turn your Play Cricket statistics into a beautiful, shareable dashboard. Batting & bowling leaderboards, multi-season combine, weekly auto-refresh.",
  brand: { "@type": "Brand", name: "ClubStats" },
  offers: {
    "@type": "Offer",
    price: "125.00",
    priceCurrency: "GBP",
    availability: "https://schema.org/InStock",
    priceValidUntil: "2026-12-31",
    url: "https://clubcricketstats.com/#order",
  },
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "ClubStats",
  url: "https://clubcricketstats.com",
  email: "hello@clubcricketstats.com",
  description:
    "Beautiful, shareable cricket dashboards for grassroots clubs across the UK.",
};
