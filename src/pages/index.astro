    <script is:inline>
      // TODO: Replace with your Stripe Payment Link URL
      const STRIPE_LINK = "https://buy.stripe.com/REPLACE_ME";

      const BASE_PRICE = 125;
      const WAS_PRICE = 199;
      const teamsSelect = document.getElementById("teams");
      const totalPrice = document.getElementById("total-price");
      const btnPrice = document.getElementById("btn-price");
      const wasPrice = document.getElementById("was-price");
      const extrasLine = document.getElementById("extras-line");

      function updatePrice() {
        const selected = teamsSelect.options[teamsSelect.selectedIndex];
        const extra = parseInt(selected.dataset.extra || "0", 10);
        const total = BASE_PRICE + extra;
        const was = WAS_PRICE + extra;

        totalPrice.textContent = total;
        btnPrice.textContent = total;
        wasPrice.innerHTML = "&pound;" + was;

        if (extra > 0) {
          extrasLine.style.display = "block";
          extrasLine.innerHTML =
            "Includes junior sections (+&pound;" + extra + ")";
        } else {
          extrasLine.style.display = "none";
        }
      }

      teamsSelect.addEventListener("change", updatePrice);

      document
        .getElementById("order-form")
        .addEventListener("submit", function (e) {
          e.preventDefault();
          const f = new FormData(this);
          const params = new URLSearchParams();
          params.set(
            "prefilled_email",
            f.get("email") || "",
          );
          const ref = [
            f.get("clubname"),
            f.get("subdomain"),
            f.get("contact"),
            f.get("role"),
            f.get("phone"),
            f.get("teams"),
            f.get("colours"),
            f.get("notes"),
          ]
            .filter(Boolean)
            .join(" | ");
          params.set("client_reference_id", ref.slice(0, 200));
          window.location.href = STRIPE_LINK + "?" + params.toString();
        });
    </script>

