---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import "../styles/landing.css";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Do you need our Play Cricket login?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes — briefly. The full stats page on Play Cricket sits behind sign-in, so we need access to capture your numbers. We arrange this securely on a quick screen-share or via a password manager link.",
      },
    },
    {
      "@type": "Question",
      name: "How current are the stats?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "On setup we pull every match from the last four seasons. During the season, we re-capture every Sunday night so Monday morning your URL is fresh.",
      },
    },
    {
      "@type": "Question",
      name: "Can I include the junior section too?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes — Under-9 through Under-18 cricket can be added as a bolt-on for £49. We add a separate Junior mode to the dashboard.",
      },
    },
    {
      "@type": "Question",
      name: "What's included in the £99/year renewal?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Weekly stats refresh through every season, all new feature releases, continued hosting, and email support. Cancel anytime.",
      },
    },
    {
      "@type": "Question",
      name: "Can we put it on our own club website?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Absolutely. The URL embeds in any club website via a single iframe tag. We send you the snippet on delivery.",
      },
    },
  ],
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "ClubStats Cricket Dashboard",
  description:
    "Turn your Play Cricket statistics into a beautiful, shareable dashboard. Batting & bowling leaderboards, multi-season combine, weekly auto-refresh.",
  brand: { "@type": "Brand", name: "ClubStats" },
  offers: {
    "@type": "Offer",
    price: "125.00",
    priceCurrency: "GBP",
    availability: "https://schema.org/InStock",
    priceValidUntil: "2026-12-31",
    url: "https://clubcricketstats.com/#order",
  },
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "ClubStats",
  url: "https://clubcricketstats.com",
  email: "hello@clubcricketstats.com",
  description:
    "Beautiful, shareable cricket dashboards for grassroots clubs across the UK.",
};
---

<BaseLayout
  title="ClubStats — Turn your Play Cricket stats into a dashboard your club will love"
  description="Turn your Play Cricket club statistics into a beautiful, shareable dashboard. Batting & bowling leaderboards, multi-season combine, weekly auto-refresh. Used by ECB Premier League clubs. £125 launch offer, live in 48 hours."
  ogTitle="ClubStats — Cricket dashboards your club will actually open"
  ogDescription="Turn your Play Cricket stats into a beautiful dashboard. Batting leaderboards, bowling spells, multi-season combine. Live in 48 hours. Launch offer £125."
  jsonLd={[faqSchema, productSchema, orgSchema]}
>
  <div class="landing">
    <nav class="top">
      <div class="container row">
        <div class="logo">Club<span class="acc">Stats</span></div>
        <ul>
          <li><a href="#features">Features</a></li>
          <li><a href="#demo">Live demo</a></li>
          <li><a href="#how">How it works</a></li>
          <li><a href="#pricing">Pricing</a></li>
          <li><a href="#faq">FAQ</a></li>
          <li><a href="#order" class="cta">Order now</a></li>
        </ul>
      </div>
    </nav>

    <section class="hero">
      <div class="container grid">
        <div>
          <h1>
            Stats your selection committee will <span class="h-acc"
              >actually open.</span
            >
          </h1>
          <p class="lede">
            Turn your <strong>Play Cricket</strong> stats into a beautiful,
            shareable dashboard your players and committee will love. No logins,
            no spreadsheets &mdash; just one link. Live in 48 hours, updated
            every week of the season.
          </p>
          <div class="ctas">
            <a href="#order" class="btn btn-primary"
              >Order for your club &mdash; &pound;125</
            >
            <a href="#demo" class="btn btn-secondary">See live demo &rarr;</a>
          </div>
          <div class="trust">
            <span><span class="tick">&#10003;</span> Live in 48 hours</span>
            <span><span class="tick">&#10003;</span> No tech setup</span>
            <span><span class="tick">&#10003;</span> Works on phone</span>
          </div>
        </div>
        <div>
          <div class="preview-wrap">
            <div class="preview-bar">
              <div class="dots"><span></span><span></span><span></span></div>
              <div class="url">clubcricketstats.com/your-club</div>
            </div>
            <div class="mini-dash">
              <div class="title-row">
                <h3>Your Club &mdash; Stats Dashboard</h3>
                <span class="pill">2025 &middot; League &middot; All</span>
              </div>
              <div class="tabs">
                <div class="tab active">Batting</div>
                <div class="tab">Bowling</div>
              </div>
            </div>
            <div class="mini-kpis">
              <div class="mini-kpi">
                <div class="l">Total Runs</div>
                <div class="v">16,275</div>
              </div>
              <div class="mini-kpi gold">
                <div class="l">Top Scorer</div>
                <div class="v">773</div>
                <div class="n">H. Weibgen</div>
              </div>
              <div class="mini-kpi gold">
                <div class="l">Top Innings</div>
                <div class="v">249</div>
                <div class="n">A. Prakasan</div>
              </div>
              <div class="mini-kpi">
                <div class="l">Most 100s</div>
                <div class="v">3</div>
                <div class="n">H. Weibgen</div>
              </div>
              <div class="mini-kpi">
                <div class="l">Most 50s</div>
                <div class="v">4</div>
                <div class="n">H. Weibgen</div>
              </div>
            </div>
            <div class="mini-table">
              <table>
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Player</th>
                    <th>Inn</th>
                    <th>Runs</th>
                    <th>Avg</th>
                    <th>HS</th>
                    <th>50s</th>
                    <th>100s</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="gold">
                    <td>1</td>
                    <td class="pl">Hugh Weibgen</td>
                    <td>13</td>
                    <td class="r">773</td>
                    <td>70.27</td>
                    <td>180</td>
                    <td>4</td>
                    <td>3</td>
                  </tr>
                  <tr>
                    <td>2</td>
                    <td class="pl">Ayush Obhrai</td>
                    <td>17</td>
                    <td class="r">560</td>
                    <td>50.91</td>
                    <td>100*</td>
                    <td>3</td>
                    <td>1</td>
                  </tr>
                  <tr>
                    <td>3</td>
                    <td class="pl">Robbie Hughes</td>
                    <td>10</td>
                    <td class="r">533</td>
                    <td>59.22</td>
                    <td>138</td>
