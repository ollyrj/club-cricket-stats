{
  "name": "clubstats",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "scrape": "npx tsx scraper/cli.ts",
    "scrape:all": "npx tsx scraper/cli.ts --all",
    "scrape:weekly": "npx tsx scraper/cli.ts --all --season=2026"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.0",
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^5.7.0",
    "cheerio": "^1.2.0",
    "minimist": "^1.2.8",
    "p-limit": "^7.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.9.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.0.0",
    "playwright": "^1.60.0",
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.22.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.1.0"
  }
}
